{
  "name": "@skylab/cms",
  "version": "0.1.0",
  "description": "Inline-editing CMS SDK for Next.js App Router projects",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server.js"
    },
    "./actions": {
      "import": "./dist/actions.js"
    },
    "./nextauth": {
      "import": "./dist/nextauth.js"
    },
    "./page": {
      "import": "./dist/page.js"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "example"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "framer-motion": "^11.11.0"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "next-auth": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "next": "^15.0.0",
    "next-auth": "^4.24.14",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
